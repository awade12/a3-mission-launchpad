{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build client and run Launchpad",
      "type": "shell",
      "command": "cd ../renderer && npm run build && cd ../app && npm run dev",
      "options": {
        "cwd": "${workspaceFolder}/launchpad_client/app"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "focus": true
      },
      "problemMatcher": []
    }
  ]
}
